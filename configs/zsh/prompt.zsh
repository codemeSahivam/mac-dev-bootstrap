# Prompt customization — edit freely, rerun ./install.sh to apply

# Prompt style: classic | macos | arrow | dev
# Switch anytime: ./scripts/switch-prompt.sh macos
export PROMPT_STYLE="${PROMPT_STYLE:-classic}"

# Short hostname in prompt (optional — uncomment to use)
# export STARSHIP_HOSTNAME="${HOSTNAME%%.*}"

# Use dev prompt with git/k8s/docker modules:
# export STARSHIP_CONFIG="${HOME}/.config/starship.dev.toml"

# Disable Starship (use plain zsh % prompt):
# export DISABLE_STARSHIP=1
